# MONGO DATABASE CONFIGURATION

MONGO_HOST=mongo-db
MONGO_PORT=27017
MONGO_USER=
MONGO_PASS=
MONGO_DB=eauction_db
MONGO_MAX_POOL=50
MONGO_MIN_POOL=10
MONGO_TIMEOUT=8000
MONGO_RETRY=true
MONGO_AUTO_INDEX=true

# BACKEND CONFIGURATION
SERVER_ADDR=0.0.0.0
SERVER_PORT=8080

JWT_SECRET=your-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRATION_MINS=60
JWT_REFRESH_TOKEN_EXPIRATION_DAYS=7

COOKIE_NAME=refresh_toke
COOKIE_HTTP_ONLY=true
COOKIE_SECURE=false
COOKIE_MAX_AGE=604800
COOKIE_SAME_SITE=Lax

VNP_TMN_CODE=your-vnp-tmn-code
VNP_HASH_SECRET=your-vnp-hash-secret
VNP_RETURN_URL=http://localhost:8080/api/v1/payments/callback/vnpay

SEPAY_API_KEY=your-sepay-api-key
SEPAY_BANK_ACCOUNT=your-sepay-bank-account
SEPAY_BANK_NAME=your-sepay-bank-name

AWS_S3_BUCKET=your-aws-s3-bucket
AWS_S3_REGION=your-aws-s3-region

